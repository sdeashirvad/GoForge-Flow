# Database — leave empty to use local SQLite (flowforge.db)
# DATABASE_URL=postgres://user:password@host:5432/flowforge

# Server port (default 8080)
PORT=8080

# Worker pool size (default 5)
WORKER_COUNT=5

# Groq API key for AI-powered diagnostics (optional)
# Without this, mock diagnostics are used — all other flows work fine.
# Get a free key at: https://console.groq.com
# GROQ_API_KEY=gsk_...

# Static files directory (default ./web/dist)
# STATIC_DIR=./web/dist
